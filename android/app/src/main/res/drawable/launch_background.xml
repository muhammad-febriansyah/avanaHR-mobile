<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash: white background + centered AvanaHR logo. Matches the
     Flutter SplashView (white + logo) so the native launch screen and the
     Flutter splash read as one seamless splash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
